---
const { platform, size = 24, class: className = "" } = Astro.props;

// Platform color mapping
const COLORS = {
  facebook: "#1877f2",
  instagram: "url(#ig-logo-grad)",
  youtube: "#ff0000",
  pinterest: "#e60023",
  x: "currentColor",
  tiktok: "currentColor"
};

const color = COLORS[platform] || "currentColor";
---

<svg width={size} height={size} viewBox="0 0 24 24" fill={color} aria-hidden="true" class={className}>
  {platform === "instagram" && (
    <defs>
      <linearGradient id="ig-logo-grad" x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="#f09433"/>
        <stop offset="25%"  stop-color="#e6683c"/>
        <stop offset="50%"  stop-color="#dc2743"/>
        <stop offset="75%"  stop-color="#cc2366"/>
        <stop offset="100%" stop-color="#bc1888"/>
      </linearGradient>
    </defs>
  )}
  
  {platform === "facebook" && (
    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
