---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/react/Header.jsx';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}
---

<BaseLayout {...Astro.props}>
  <Header client:load />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
