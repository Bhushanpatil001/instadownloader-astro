---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/react/ContactForm.jsx';

const CONTACT_INFO = [
    { icon: '🐛', title: 'Bug Reports',         desc: 'Found something broken? Let us know and we\'ll fix it ASAP.' },
    { icon: '⚖️',  title: 'DMCA / Copyright',  desc: 'We respect intellectual property. Send a formal DMCA request.' },
    { icon: '💡', title: 'Feature Requests',    desc: 'Have a platform or feature suggestion? We love hearing ideas.' },
    { icon: '🤝', title: 'Partnerships',        desc: 'Interested in advertising or collaboration opportunities.' },
];
---

<PageLayout
  title="Contact Us — Downloader | Get Help & Support"
  description="Contact the Downloader team for support, bug reports, DMCA takedowns, or general inquiries. We typically respond within 24 hours."
>
  <div class="max-w-[1000px] mx-auto px-6 py-5">
    <div class="text-center mb-6">
      <div class="inline-flex px-4 py-1.5 rounded-full text-sm font-bold bg-[rgba(124,58,237,0.1)] border border-[rgba(124,58,237,0.2)] text-[var(--brand2)] mb-3">✉️ Get in Touch</div>
      <h1 class="text-[clamp(1.8rem,4vw,2.8rem)] font-black mb-1 leading-tight" style="color:var(--txt);">
        Contact <span style="background:var(--g-brand); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Us</span>
      </h1>
      <p class="text-lg opacity-70 max-w-[700px] mx-auto">
        Have a question, a bug to report, or a DMCA request? We're here to help and usually respond within 24 hours.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      {CONTACT_INFO.map(({ icon, title, desc }) => (
        <div class="p-6 rounded-[20px] border border-[var(--bdr)]" style="background:var(--bg-glass);">
          <div class="text-[1.8rem] mb-3">{icon}</div>
          <h3 class="font-bold text-sm mb-2" style="color:var(--txt);">{title}</h3>
          <p class="text-[0.8rem] leading-relaxed opacity-60" style="color:var(--txt3);">{desc}</p>
        </div>
      ))}
    </div>

    <ContactForm client:load />
  </div>
</PageLayout>
