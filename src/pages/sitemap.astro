---
import PageLayout from '../layouts/PageLayout.astro';

const PAGES = [
    {
        category: 'Downloaders',
        links: [
            { href: '/',                               label: 'Home — Universal Downloader' },
            { href: '/instagram',                      label: 'Instagram Downloader' },
            { href: '/instagram-reels-downloader',     label: 'Instagram Reels Downloader' },
            { href: '/yt',                             label: 'YouTube Downloader' },
            { href: '/youtube-shorts-downloader',      label: 'YouTube Shorts Downloader' },
            { href: '/facebook',                       label: 'Facebook Video Downloader' },
            { href: '/pinterest',                      label: 'Pinterest Video Downloader' },
            { href: '/x',                              label: 'X (Twitter) Video Downloader' },
            { href: '/tiktok',                         label: 'TikTok Video Downloader' },
        ],
    },
    {
        category: 'Company',
        links: [
            { href: '/about',    label: 'About Us' },
            { href: '/contact',  label: 'Contact Us' },
        ],
    },
    {
        category: 'Legal',
        links: [
            { href: '/privacy-policy',  label: 'Privacy Policy' },
            { href: '/terms',           label: 'Terms of Use' },
            { href: '/disclaimer',      label: 'Disclaimer' },
            { href: '/cookies-policy',  label: 'Cookies Policy' },
        ],
    },
];
---

<PageLayout
  title="Sitemap — Downloader | All Pages"
  description="Full sitemap of Downloader — find all downloader tools, legal pages, and company information."
>
  <div class="max-w-[1000px] mx-auto px-6 py-5">
    <div class="text-center mb-6">
      <div class="inline-flex px-4 py-1.5 rounded-full text-sm font-bold bg-[rgba(124,58,237,0.1)] border border-[rgba(124,58,237,0.2)] text-[var(--brand2)] mb-3">🗺️ Navigation</div>
      <h1 class="text-[clamp(1.8rem,4vw,2.8rem)] font-black mb-1 leading-tight" style="color:var(--txt);">Sitemap</h1>
      <p class="text-lg opacity-70">All pages and tools available on Downloader.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {PAGES.map(({ category, links }) => (
        <div class="p-8 rounded-[32px] border border-[var(--bdr)]" style="background:var(--bg-glass);">
          <h2 class="text-xs font-bold uppercase tracking-widest opacity-50 mb-6" style="color:var(--txt);">
            {category}
          </h2>
          <ul class="flex flex-col gap-4">
            {links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm font-medium transition-all hover:text-[var(--brand2)] flex items-center gap-2 group" style="color:var(--txt2);">
                  <span class="text-[var(--brand)] transition-transform group-hover:translate-x-1">→</span>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</PageLayout>
